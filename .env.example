# ============================================================================
# MoneyPenny — example environment file
# Copy to .env and fill in real values:   cp .env.example .env
# Everything here is read via config.py (python-dotenv loads .env at import).
# ============================================================================

# ── LLM ──────────────────────────────────────────────────────────────────────
# PydanticAI model string. Examples:
#   openai:gpt-4o
#   google-gla:gemini-1.5-pro
AI_MODEL=openai:gpt-4o
OPENAI_API_KEY=sk-...                 # required when AI_MODEL starts with "openai:"

# Optional: a custom OpenAI-compatible endpoint
BASE_URL=
API_KEY=

# ── Realtime audio (voice mode) ──────────────────────────────────────────────
REALTIME_MODEL=gpt-4o-mini-realtime-preview
REALTIME_VOICE=nova                   # alloy, ash, ballad, coral, echo, sage, shimmer, verse

# ── Web search (event lookup) ────────────────────────────────────────────────
SERPER_API_KEY=

# ── Email sending (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Moneypenny <onboarding@resend.dev>

# ── Observability (Arize Phoenix) ─────────────────────────────────────────────
# Local:  uv run phoenix serve  →  UI at http://localhost:6006
# Cloud:  https://app.phoenix.arize.com  →  see docs/observability/phoenix.md
PHOENIX_ENABLED=1
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_PROJECT_NAME=moneypenny
# Required for Phoenix Cloud (leave empty for local dev):
PHOENIX_API_KEY=
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/<your-space>
CONSENT_EVAL_ENABLED=1
KILL_SWITCH_ON_BYPASS=1

# ── Backend server (Phase 2) ─────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8765
CORS_ORIGINS=*

# ── Redis (optional — teammate wires user DB + memory; ledger uses same URL) ─
# When set, consent ledger uses Redis Streams instead of .consent/ledger.jsonl
REDIS_URL=

# ── Knowledge base ───────────────────────────────────────────────────────────
FILE_PATH=./knowledge_base

# ── Consent gate / ledger ────────────────────────────────────────────────────
# Server-side secret used to mint Consent_Tokens (HMAC-SHA256). CHANGE in prod.
CONSENT_SECRET=moneypenny-dev-consent-secret-change-me

# ── Google Workspace (Drive / Gmail / Calendar) ──────────────────────────────
# Create a "Desktop app" OAuth client in Google Cloud Console, enable the
# Drive / Gmail / Calendar APIs, and add your account as a test user.
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8765/oauth2callback
CALENDAR_TIMEZONE=America/Los_Angeles
# Where the encrypted Workspace refresh token is stored (gitignored).
WORKSPACE_TOKEN_PATH=.workspace/credentials.enc
# Secret used to encrypt the stored token at rest. Falls back to CONSENT_SECRET.
WORKSPACE_TOKEN_KEY=

# ── Runtime mode ─────────────────────────────────────────────────────────────
# 1 (default) = simulate real-world actions. Set to 0 to perform REAL actions.
MONEYPENNY_DEMO=1

# ============================================================================
# Test-only toggles (used by tests/workspace/*_integration.py — NOT by the app)
# These are normally set inline in your shell when running live tests, but you
# can keep them here too. See the test commands in the README / chat.
# ============================================================================
# Opt in to live Google API tests (must also set MONEYPENNY_DEMO=0):
RUN_GOOGLE_INTEGRATION=
# Optional: a real address to test Drive sharing (sends nothing unless set):
GOOGLE_TEST_SHARE_EMAIL=
# Optional: a real address to test Calendar invitations (sends a real invite):
GOOGLE_TEST_INVITE_EMAIL=
